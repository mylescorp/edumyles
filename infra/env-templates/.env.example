# =============================================================================
# EduMyles — Environment Variables Template
# =============================================================================
# Copy this file to the appropriate package:
#   cp infra/env-templates/.env.example frontend/.env.local
#   cp infra/env-templates/.env.example landing/.env.local
#
# NEVER commit real values. All secrets are stored in GitHub Org Secrets
# and injected at build time via Vercel / CI environment.
# =============================================================================


# -----------------------------------------------------------------------------
# CONVEX — Real-time Serverless Backend
# https://dashboard.convex.dev
# -----------------------------------------------------------------------------

# Convex deployment URL (from `npx convex dev` output)
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# Convex deploy key (used in CI/CD to push backend)
CONVEX_DEPLOY_KEY=prod:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Convex admin key (server-side only — never expose to browser)
CONVEX_ADMIN_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# WORKOS — Authentication (Magic Links, SSO, Organizations)
# https://dashboard.workos.com
# -----------------------------------------------------------------------------

# WorkOS API key (server-side only)
WORKOS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WorkOS Client ID (safe for browser)
NEXT_PUBLIC_WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WorkOS redirect URI after authentication
WORKOS_REDIRECT_URI=https://{slug}.edumyles.com/auth/callback

# Cookie secret for session encryption (min 32 chars, random string)
WORKOS_COOKIE_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# VERCEL — Hosting & Subdomain Routing
# https://vercel.com/dashboard
# -----------------------------------------------------------------------------

# Vercel project ID (from vercel.json or project settings)
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel team/org ID
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel access token (for deploy scripts)
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Root domain used for subdomain routing
NEXT_PUBLIC_ROOT_DOMAIN=edumyles.com


# -----------------------------------------------------------------------------
# M-PESA / DARAJA — Safaricom Mobile Money (Kenya)
# https://developer.safaricom.co.ke
# -----------------------------------------------------------------------------

# Daraja consumer key (from your Daraja app)
MPESA_CONSUMER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Daraja consumer secret
MPESA_CONSUMER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Lipa na M-Pesa Online (STK Push) shortcode
MPESA_SHORTCODE=174379

# Lipa na M-Pesa passkey
MPESA_PASSKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# STK push callback URL (must be HTTPS, publicly reachable)
MPESA_CALLBACK_URL=https://api.edumyles.com/webhooks/mpesa

# Daraja environment: "sandbox" | "production"
MPESA_ENVIRONMENT=sandbox


# -----------------------------------------------------------------------------
# AIRTEL MONEY — Airtel Mobile Money
# https://developers.airtel.africa
# -----------------------------------------------------------------------------

AIRTEL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTEL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTEL_CALLBACK_URL=https://api.edumyles.com/webhooks/airtel

# Airtel environment: "staging" | "production"
AIRTEL_ENVIRONMENT=staging


# -----------------------------------------------------------------------------
# STRIPE — Card Payments (International)
# https://dashboard.stripe.com
# -----------------------------------------------------------------------------

# Stripe publishable key (safe for browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret (from `stripe listen` output or dashboard)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# AFRICA'S TALKING — SMS Gateway
# https://account.africastalking.com
# -----------------------------------------------------------------------------

# Africa's Talking username (use "sandbox" for testing)
AT_USERNAME=sandbox

# Africa's Talking API key
AT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Africa's Talking sender ID (shortcode or alphanumeric, leave blank for default)
AT_SENDER_ID=EduMyles


# -----------------------------------------------------------------------------
# RESEND — Transactional Email
# https://resend.com/api-keys
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address for transactional emails (must be a verified domain)
RESEND_FROM_EMAIL=noreply@edumyles.com
RESEND_FROM_NAME=EduMyles


# -----------------------------------------------------------------------------
# APPLICATION — Runtime Config
# -----------------------------------------------------------------------------

# Node environment: "development" | "staging" | "production"
NODE_ENV=development

# Log level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=debug

# Next.js app URL (used for absolute URL generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Landing page URL
NEXT_PUBLIC_LANDING_URL=http://localhost:3001

# Platform master admin secret (for platform-level operations)
PLATFORM_ADMIN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# OPTIONAL — Future / Planned Integrations
# -----------------------------------------------------------------------------

# Sentry — Error monitoring
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx
# SENTRY_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG=mylesoft-technologies
# SENTRY_PROJECT=edumyles

# PostHog — Product analytics
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Cloudinary — Media / document uploads
# CLOUDINARY_CLOUD_NAME=xxxxxxxx
# CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
