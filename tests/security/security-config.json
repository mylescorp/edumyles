{
  "securityAudit": {
    "version": "1.0.0",
    "description": "Comprehensive security audit configuration for EduMyles",
    "lastUpdated": "2024-03-04"
  },
  "tenantIsolation": {
    "enabled": true,
    "strictMode": true,
    "validation": {
      "tenantIdRequired": true,
      "crossTenantAccessPrevention": true,
      "dataOwnershipValidation": true,
      "resourceLevelIsolation": true
    },
    "enforcement": {
      "queryLevel": true,
      "mutationLevel": true,
      "fileAccess": true,
      "apiEndpoints": true,
      "sessionManagement": true
    }
  },
  "authentication": {
    "passwordPolicy": {
      "minLength": 8,
      "requireUppercase": true,
      "requireLowercase": true,
      "requireNumbers": true,
      "requireSpecialChars": true,
      "preventCommonPasswords": true,
      "maxAge": 90,
      "historyCount": 5
    },
    "sessionManagement": {
      "timeout": 30,
      "maxConcurrentSessions": 3,
      "secureCookies": true,
      "httpOnly": true,
      "sameSite": "strict"
    },
    "rateLimiting": {
      "loginAttempts": 5,
      "lockoutDuration": 15,
      "generalRequests": 1000,
      "windowMinutes": 1
    }
  },
  "authorization": {
    "rbac": {
      "enabled": true,
      "strictMode": true,
      "defaultDeny": true
    },
    "permissions": {
      "admin": ["users:read", "users:write", "users:delete", "system:read", "system:write", "audit:read", "reports:read"],
      "teacher": ["students:read", "assignments:read", "assignments:write", "grades:read", "grades:write", "attendance:read", "attendance:write"],
      "student": ["profile:read", "profile:write", "assignments:read", "grades:read"],
      "parent": ["children:read", "payments:read", "grades:read", "attendance:read"]
    },
    "resourceOwnership": {
      "enabled": true,
      "strictValidation": true,
      "crossTenantPrevention": true
    }
  },
  "inputValidation": {
    "xssPrevention": {
      "enabled": true,
      "sanitization": true,
      "contentSecurityPolicy": true
    },
    "sqlInjection": {
      "enabled": true,
      "parameterizedQueries": true,
      "inputSanitization": true
    },
    "nosqlInjection": {
      "enabled": true,
      "inputValidation": true,
      "querySanitization": true
    },
    "fileUpload": {
      "allowedTypes": ["image/jpeg", "image/png", "image/gif", "image/webp", "application/pdf", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"],
      "maxSize": "10MB",
      "virusScanning": true,
      "contentValidation": true
    }
  },
  "dataProtection": {
    "encryption": {
      "atRest": true,
      "inTransit": true,
      "algorithm": "AES-256",
      "keyRotation": 90
    },
    "sensitiveData": {
      "fields": ["password", "ssn", "creditCard", "bankAccount", "medicalRecords", "personalDocuments"],
      "masking": true,
      "accessLogging": true
    },
    "dataRetention": {
      "logs": 365,
      "auditTrails": 2555,
      "userSessions": 30,
      "temporaryFiles": 7
    }
  },
  "apiSecurity": {
    "cors": {
      "enabled": true,
      "allowedOrigins": ["https://app.edumyles.com", "https://staging.edumyles.com"],
      "allowedMethods": ["GET", "POST", "PUT", "DELETE"],
      "allowedHeaders": ["Content-Type", "Authorization"],
      "credentials": true
    },
    "securityHeaders": {
      "X-Content-Type-Options": "nosniff",
      "X-Frame-Options": "DENY",
      "X-XSS-Protection": "1; mode=block",
      "Strict-Transport-Security": "max-age=31536000; includeSubDomains",
      "Content-Security-Policy": "default-src 'self'",
      "Referrer-Policy": "strict-origin-when-cross-origin"
    },
    "rateLimiting": {
      "global": {"requests": 10000, "window": "1m"},
      "perUser": {"requests": 1000, "window": "1m"},
      "perTenant": {"requests": 5000, "window": "1m"}
    }
  },
  "monitoring": {
    "securityEvents": {
      "enabled": true,
      "logLevel": "info",
      "retention": 365,
      "alerts": {
        "failedLogins": {"threshold": 10, "window": "5m", "severity": "high"},
        "crossTenantAccess": {"threshold": 1, "window": "1m", "severity": "critical"},
        "privilegeEscalation": {"threshold": 1, "window": "1m", "severity": "critical"}
      }
    },
    "auditLogging": {
      "enabled": true,
      "allRequests": false,
      "sensitiveOperations": true,
      "dataAccess": true,
      "authentication": true,
      "authorization": true
    }
  },
  "testing": {
    "securityTests": {
      "authentication": {"weakPasswords": true, "sqlInjection": true, "sessionHijacking": true, "bruteForce": true},
      "authorization": {"privilegeEscalation": true, "crossTenantAccess": true, "resourceOwnership": true, "roleBasedAccess": true},
      "inputValidation": {"xss": true, "csrf": true, "fileUpload": true, "apiInjection": true},
      "tenantIsolation": {"dataAccess": true, "queryFiltering": true, "fileAccess": true, "apiEndpoints": true}
    },
    "penetrationTesting": {
      "enabled": true,
      "frequency": "monthly",
      "scope": "external",
      "tools": ["OWASP ZAP", "Burp Suite", "Nmap"]
    },
    "vulnerabilityScanning": {
      "enabled": true,
      "frequency": "weekly",
      "dependencies": true,
      "codeAnalysis": true
    }
  },
  "compliance": {
    "standards": ["GDPR", "FERPA", "COPPA", "SOC2", "ISO27001"],
    "dataPrivacy": {
      "consentManagement": true,
      "dataMinimization": true,
      "rightToErasure": true,
      "dataPortability": true
    },
    "reporting": {
      "securityIncidents": true,
      "dataBreaches": true,
      "complianceStatus": true,
      "auditReports": true
    }
  },
  "incidentResponse": {
    "procedures": {
      "detection": "automated",
      "containment": "immediate",
      "eradication": "24h",
      "recovery": "48h",
      "postIncident": "72h"
    },
    "escalation": {
      "level1": "security@edumyles.com",
      "level2": "cto@edumyles.com",
      "level3": "executive@edumyles.com"
    },
    "documentation": {
      "required": true,
      "template": "security-incident-report",
      "retention": 7
    }
  },
  "environments": {
    "development": {"securityLevel": "medium", "monitoring": "basic", "testing": "full"},
    "staging": {"securityLevel": "high", "monitoring": "full", "testing": "full"},
    "production": {"securityLevel": "maximum", "monitoring": "full", "testing": "minimal"}
  }
}
