{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "dev": "expo start",
    "build": "node ../node_modules/typescript/bin/tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "type-check": "node ../node_modules/typescript/bin/tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist .expo tsconfig.tsbuildinfo"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.{ts,tsx}",
      "**/src/**/*.test.{ts,tsx}"
    ],
    "moduleNameMapper": {
      "^@edumyles/shared$": "<rootDir>/../shared/src/index.ts",
      "^@edumyles/shared/(.*)$": "<rootDir>/../shared/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|convex)"
    ],
    "setupFiles": [
      "./src/__tests__/setup.ts"
    ]
  },
  "dependencies": {
    "@edumyles/shared": "*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "convex": "^1.34.1",
    "expo": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.22",
    "expo-device": "~55.0.12",
    "expo-notifications": "~55.0.16",
    "expo-secure-store": "~55.0.11",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.0.0",
    "@types/react": "^19.1.1",
    "jest": "^29.0.0",
    "jest-expo": "~55.0.0",
    "typescript": "*"
  }
}
