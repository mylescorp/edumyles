NEXT_PUBLIC_LANDING_URL=https://edumyles.com
NEXT_PUBLIC_APP_URL=https://app.edumyles.com

# Convex backend used by landing API routes for waitlist, demo, partner, chat,
# WhatsApp tracking, and landing engagement records.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_URL=https://your-deployment.convex.cloud

# Transactional email / notification delivery.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=EduMyles <noreply@edumyles.com>
RESEND_SUPPORT_EMAIL=support@edumyles.com
DEMO_NOTIFY_EMAIL=sales@edumyles.com
WAITLIST_NOTIFY_EMAIL=sales@edumyles.com

# WorkOS auth used by landing auth routes.
WORKOS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_REDIRECT_URI=https://edumyles.com/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://edumyles.com/auth/callback
WORKOS_COOKIE_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cal.com demo-booking webhook secret for /api/webhooks/cal/demo.
CALCOM_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics / Ads tracking for paid campaigns.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION=AW-XXXXXXXXXX/lead_conversion_label
