# ============================================================
# EduMyles — .gitignore
# ============================================================

# ------ Environment ------
.env
.env.*
!.env.example
!infra/env-templates/.env.example

# ------ Node ------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ------ Turbo ------
.turbo/

# ------ TypeScript ------
dist/
build/
*.tsbuildinfo

# ------ Next.js ------
.next/
out/
next-env.d.ts

# ------ Expo / React Native ------
.expo/
android/
ios/
*.jks
*.keystore
*.mobileprovision
*.p12
*.cer

# ------ Convex ------
.convex/
convex/_generated/

# ------ Vercel ------
.vercel/

# ------ OS ------
.DS_Store
Thumbs.db
*.swp

# ------ IDE ------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.user

# ------ Testing ------
coverage/
.nyc_output/

# ------ Docs ------
# PDFs are stored externally, not in git
docs/**/*.pdf
.env.local
