# ============================================================
# EduMyles — .gitignore
# ============================================================

# ------ Environment ------
.env
.env.*
!.env.example

# ------ Node ------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ------ Turbo ------
.turbo/

# ------ TypeScript ------
dist/
build/
*.tsbuildinfo

# ------ Next.js ------
.next/
out/
next-env.d.ts

# ------ Expo / React Native ------
.expo/
android/
ios/
*.jks
*.keystore
*.mobileprovision
*.p12
*.cer

# ------ Convex ------
.convex/
.convex-temp/

# ------ Vercel ------
.vercel/

# ------ OS ------
.DS_Store
Thumbs.db
*.swp

# ------ IDE ------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.user

# ------ Testing ------
coverage/
.nyc_output/
playwright-report/
test-results/
.e2e-runtime/
e2e/.auth/*.json

# ------ Claude ------
.claude/

# ------ Docs ------
docs/**/*.pdf
.vercel
.env*.local

# opensrc - source code for packages
opensrc/

.codex-logs/

.codex-logs/
