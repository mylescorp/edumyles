{
  "name": "frontend",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src eslint.config.mjs",
    "lint:fix": "eslint src eslint.config.mjs --fix",
    "type-check": "node ../node_modules/typescript/bin/tsc --noEmit",
    "clean": "rm -rf .next out tsconfig.tsbuildinfo",
    "test": "node ../node_modules/vitest/vitest.mjs",
    "test:ui": "node ../node_modules/vitest/vitest.mjs --ui",
    "test:run": "node ../node_modules/vitest/vitest.mjs run",
    "bundle:analyze": "npm run build && npx @next/bundle-analyzer",
    "perf:audit": "npm run build && npx lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html"
  },
  "dependencies": {
    "@convex-dev/react-query": "^0.1.0",
    "@edumyles/shared": "*",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/speed-insights": "^1.3.1",
    "@workos-inc/node": "^8.8.0",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.575.0",
    "next": "^15.0.0",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "*",
    "vitest": "^4.0.18"
  }
}
