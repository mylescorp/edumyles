# =============================================================================
# EduMyles Frontend — Environment Variables Template
# =============================================================================
# Copy to frontend/.env.local for local development.
# Store production values in Vercel project environment variables.
# =============================================================================

# Public URLs
NEXT_PUBLIC_APP_URL=https://app.edumyles.com
NEXT_PUBLIC_FRONTEND_URL=https://app.edumyles.com
NEXT_PUBLIC_PLATFORM_URL=https://app.edumyles.com/platform
NEXT_PUBLIC_LANDING_URL=https://edumyles.com
NEXT_PUBLIC_MARKETING_SITE_URL=https://edumyles.com
NEXT_PUBLIC_ROOT_DOMAIN=edumyles.com
NEXT_PUBLIC_AUTH_BASE_URL=https://app.edumyles.com

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WorkOS
WORKOS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_REDIRECT_URI=https://app.edumyles.com/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://app.edumyles.com/auth/callback
WORKOS_COOKIE_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_COOKIE_NAME=edumyles_session
WORKOS_ORGANIZATION_ID=org_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_PLATFORM_ORG_ID=org_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MASTER_ADMIN_EMAIL=admin@edumyles.com
MASTER_ADMIN_EMAILS=admin@edumyles.com
MASTER_ADMIN_WORKOS_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Payments
MPESA_CONSUMER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MPESA_CONSUMER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MPESA_SHORTCODE=174379
MPESA_PASSKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MPESA_CALLBACK_URL=https://app.edumyles.com/api/webhooks/mpesa
MPESA_ENVIRONMENT=production
MPESA_ALLOWED_IPS=
AIRTEL_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email, SMS, AI
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@edumyles.com
RESEND_FROM_NAME=EduMyles
RESEND_SUPPORT_EMAIL=support@edumyles.com
AT_USERNAME=edumyles
AT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_REPORT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SITE_URL=https://app.edumyles.com
OPENROUTER_APP_NAME=EduMyles
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Analytics / ads
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION=AW-XXXXXXXXXX/lead_conversion_label
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_HOST=https://app.posthog.com

# Social publishing / integrations
SOCIAL_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOCIAL_SANDBOX_MODE=false
SOCIAL_FORCE_LIVE_PUBLISH=true
FACEBOOK_APP_ID=xxxxxxxxxxxxxxxx
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TIKTOK_CLIENT_KEY=xxxxxxxxxxxxxxxx
TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_CLIENT_ID=xxxxxxxxxxxxxxxx
TWITTER_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notifications / DevOps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
PLATFORM_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SECURITY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_API_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bank transfer
BANK_ACCOUNT_NUMBER=1234567890
BANK_NAME=Equity Bank
BANK_BRANCH=Nairobi CBD Branch
BANK_SWIFT=EQBLKENA

# Runtime
NODE_ENV=production
ENABLE_DEV_AUTH_BYPASS=false
PLATFORM_ADMIN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

