{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "strict": true,
    "noImplicitAny": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/convex/*": [
        "./convex/*"
      ],
      "@shared/*": [
        "../shared/src/*"
      ],
      "@shared/types": [
        "../shared/src/types/index.ts"
      ],
      "@shared/constants": [
        "../shared/src/constants/index.ts"
      ],
      "@shared/validators": [
        "../shared/src/validators/index.ts"
      ],
      "../../convex/_generated/api": [
        "../convex/_generated/api"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/test/**/*",
    "vitest.config.ts"
  ]
}
