{
  "name": "edumyles",
  "version": "0.1.0",
  "private": true,
  "description": "EduMyles — Multi-tenant school management platform for East Africa",
  "workspaces": [
    "frontend",
    "mobile",
    "shared",
    "landing"
  ],
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "node node_modules/turbo/bin/turbo run build",
    "dev": "node node_modules/turbo/bin/turbo run dev --parallel",
    "dev:frontend": "node node_modules/turbo/bin/turbo run dev --filter=frontend",
    "dev:backend": "cd convex && node ../node_modules/convex/bin/main.js dev",
    "dev:landing": "node node_modules/turbo/bin/turbo run dev --filter=landing",
    "dev:mobile": "node node_modules/turbo/bin/turbo run dev --filter=mobile",
    "lint": "node node_modules/turbo/bin/turbo run lint",
    "lint:fix": "node node_modules/turbo/bin/turbo run lint:fix",
    "type-check": "node node_modules/turbo/bin/turbo run type-check",
    "test": "node node_modules/turbo/bin/turbo run test",
    "test:tenant-isolation": "vitest run --config vitest.tenant-isolation.config.ts",
    "clean": "node node_modules/turbo/bin/turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "add-master-admin": "node scripts/add-master-admin.js",
    "verify-master-admin": "node scripts/verify-master-admin.js",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=chromium e2e/public-pages.spec.ts e2e/admin-dashboard.spec.ts e2e/platform-security.spec.ts e2e/student-portal.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "seed:dev": "node scripts/seed-cli.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^26.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "overrides": {
    "@vitest/ui": "^4.0.0",
    "react": "19.2.4"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@convex-dev/workos-authkit": "^0.1.7",
    "@types/qrcode": "^1.5.6",
    "@vercel/speed-insights": "^1.3.1",
    "@workos-inc/node": "^8.11.0",
    "autoskills": "^0.2.3",
    "convex": "^1.34.1",
    "isomorphic-dompurify": "^2.24.0",
    "next": "^16.2.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  }
}
