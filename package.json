{
  "name": "edumyles",
  "version": "0.1.0",
  "private": true,
  "description": "EduMyles — Multi-tenant school management platform for East Africa",
  "workspaces": [
    "frontend",
    "mobile",
    "shared",
    "landing"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "node node_modules/turbo/bin/turbo run build",
    "dev": "node node_modules/turbo/bin/turbo run dev --parallel",
    "dev:frontend": "node node_modules/turbo/bin/turbo run dev --filter=frontend",
    "dev:backend": "cd convex && node ../node_modules/convex/bin/main.js dev",
    "dev:landing": "node node_modules/turbo/bin/turbo run dev --filter=landing",
    "dev:mobile": "node node_modules/turbo/bin/turbo run dev --filter=mobile",
    "lint": "node node_modules/turbo/bin/turbo run lint",
    "lint:fix": "node node_modules/turbo/bin/turbo run lint:fix",
    "type-check": "node node_modules/turbo/bin/turbo run type-check",
    "test": "node node_modules/turbo/bin/turbo run test",
    "clean": "node node_modules/turbo/bin/turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.27",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@vercel/speed-insights": "^1.3.1",
    "convex": "^1.32.0"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mylesoft-Technologies/edumyles.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Mylesoft-Technologies/edumyles/issues"
  },
  "homepage": "https://github.com/Mylesoft-Technologies/edumyles#readme"
}
